# ── AVTPP server environment (example) ──
# Copy to .env for local dev. In production set these in your host's dashboard.

# Database — use EITHER a connection URL or the discrete DB_* vars below.
# DATABASE_URL=mysql://user:password@host:3306/dbname
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=avtpp_db
# Set to true if your managed MySQL requires TLS (most do)
DB_SSL=false

# Auth / security — CHANGE THESE IN PRODUCTION
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=24h
GATE_API_KEY=change_me_gate_device_key

# Server
PORT=5000
# Seed reference data automatically on first boot (empty DB). Set false to disable.
SEED_ON_START=true
# Comma-separated extra browser origins allowed by CORS (only needed for a split deploy)
# CORS_ORIGIN=https://your-frontend.example.com

# Mobile-money gateway (simulation by default)
FLUTTERWAVE_LIVE=false
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxx
